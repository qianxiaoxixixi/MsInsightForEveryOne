{
    "name": "profiler-server",
    "version": "1.0.0",
    "main": "app.js",
    "license": "MIT",
    "bin": "./dist/app.js",
    "private": true,
    "dependencies": {
        "crypto-js": "^4.1.1",
        "lodash": "4.17.21",
        "log4js": "6.7.1",
        "threads": "^1.7.0",
        "ws": "^8.5.0"
    },
    "devDependencies": {
        "electron": "24.1.2",
        "electron-builder": "23.0.4"
    },
    "scripts": {
        "packWin": "electron-packager ./ profiler-server --platform=win32 --arch=x64 --electron-version=24.1.2 --download.mirrorOptions.mirror=http://mirrors.tools.huawei.com/electron/",
        "packLinux": "electron-packager ./ profiler-server --platform=linux --arch=x64 --electron-version=24.1.2 --download.mirrorOptions.mirror=http://mirrors.tools.huawei.com/electron/"
    },
    "build": {
        "appId": "ascend.insight.server",
        "productName": "profiler-server",
        "copyright": "Copyright © 2021 Huawei",
        "directories": {
            "buildResources": "build",
            "output": "dist"
        },
        "electronDownload": {
            "mirror": "https://npm.taobao.org/mirrors/electron/"
        },
        "electronVersion": "24.1.2",
        "win": {
            "target": "nsis"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "runAfterFinish": true
        }
    }
}
