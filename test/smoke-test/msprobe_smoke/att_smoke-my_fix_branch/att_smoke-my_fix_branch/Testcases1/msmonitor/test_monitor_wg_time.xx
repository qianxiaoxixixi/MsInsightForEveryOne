#!/bin/bash
##################### 所有脚本一样 ###################
cur_dir=$(dirname $(readlink -f $0))


export ASCEND_SLOG_PRINT_TO_STDOUT=0
export ASCEND_GLOBAL_LOG_LEVEL=0

source ${cur_dir}/../../Utils/conf.sh
source ${cur_dir}/utils/common_utils.sh

main() {
    file_name=$(basename $0 .sh)
    testcase_result_dir="${output_dir}/msmonitor/${file_name}"
    if [ ! -d ${testcase_result_dir} ]; then
        mkdir -p ${testcase_result_dir}
    else
        rm -rf ${testcase_result_dir}/*
    fi
    export MONITOR_OUTPUT_DIR=${testcase_result_dir}
    # export MONITOR_OUTPUT_DIR=/home/maoyanlong/att_smoke_new/WorkSpace1/amon
    start_time=$(date "+%s")

    cd $MODEL_PATH
    # cd /home/maoyanlong/att_smoke_new/Model_msmonitor/Model/ModelLink

    # bash examples/llama2/test_wg_time_base.sh  > /home/maoyanlong/att_smoke_new/WorkSpace1/amon/plog_base.txt 2>&1
    local base_log="${testcase_result_dir}/plog_base.txt"
    bash examples/llama2/test_wg_time_base.sh  > ${base_log} 2>&1
    # local base_log="/home/maoyanlong/att_smoke_new/WorkSpace1/amon/plog_base.txt"
    base_train_start_times=$(grep "iteration        5/      10" ${base_log} | grep -oP '\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}')
    base_train_end_times=$(grep "\[after training is done] datetime:" ${base_log} | grep -oP '\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}')

    base_start_time=$(date -d "$base_train_start_times" +%s)
    base_end_time=$(date -d "$base_train_end_times" +%s)

    base_use_time=$((base_end_time-base_start_time))
    echo "[INFO] base use time: ${base_use_time}s"


    
    bash examples/llama2/test_wg_time.sh  > ${testcase_result_dir}/plog.txt 2>&1

    # bash examples/llama2/test_wg_time.sh  > /home/maoyanlong/att_smoke_new/WorkSpace1/amon/plog.txt 2>&1

    verify_csv_output 20

    local tool_log="${testcase_result_dir}/plog.txt"
    # local tool_log="/home/maoyanlong/att_smoke_new/WorkSpace1/amon/plog.txt"
    tool_train_start_times=$(grep "iteration        5/      10" ${tool_log} | grep -oP '\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}')
    tool_train_end_times=$(grep "\[after training is done] datetime:" ${tool_log} | grep -oP '\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}')

    tool_start_time=$(date -d "$tool_train_start_times" +%s)
    tool_end_time=$(date -d "$tool_train_end_times" +%s)

    tool_use_time=$((tool_end_time-tool_start_time))
    echo "[INFO] tool use time: ${tool_use_time}s"

    time_performance_check ${base_use_time} ${tool_use_time}
    end_time=$(date "+%s")
    duration_time=$(( ${end_time} - ${start_time} ))

    echo "${file_name} pass ${duration_time} ${pytorch_branchs}"
}

main
